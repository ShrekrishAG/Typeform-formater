# Server (Render sets PORT automatically in production)
PORT=3847

# Must match Google Apps Script → Script Properties → WEBHOOK_SECRET
WEBHOOK_SECRET=your-long-random-secret-here

# HR receives the PDF here
HR_EMAIL=hr@yourcompany.com

# Resend: https://resend.com
RESEND_API_KEY=re_xxxxxxxx
FROM_EMAIL=notifications@yourcompany.com

# Optional: shown on the PDF cover
FORM_TITLE=New Career Interest Form Submission
COMPANY_NAME=Your Company

# Optional: override Chrome path (local Mac usually auto-detected)
# PUPPETEER_EXECUTABLE_PATH=/Applications/Google Chrome.app/Contents/MacOS/Google Chrome
